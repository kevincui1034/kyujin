# Auth.js
AUTH_SECRET="generate with: openssl rand -base64 32"
AUTH_URL="http://localhost:3100"
AUTH_TRUST_HOST="true"

# Google OAuth (login)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Apple OAuth (login, optional — leave blank to disable Apple sign-in)
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# Gmail OAuth (separate grant for gmail.readonly)
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI="http://localhost:3100/api/gmail/callback"
GMAIL_PUBSUB_TOPIC="projects/your-gcp-project/topics/kyujin-gmail"

# Database (Supabase / Neon Postgres)
DATABASE_URL=""

# Vercel AI Gateway
AI_GATEWAY_API_KEY=""

# Cron auth — header value Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET="generate with: openssl rand -base64 32"
