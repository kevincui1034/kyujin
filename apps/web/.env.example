# Auth.js
AUTH_SECRET="generate with: openssl rand -base64 32"
AUTH_URL="http://localhost:3100"
AUTH_TRUST_HOST="true"

# Google OAuth (login)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Apple OAuth (login, optional — leave blank to disable Apple sign-in)
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# Email provider selector. "gmail" uses our own CASA-bound Google OAuth client
# (requires Google verification + CASA Tier 2 audit to support real users).
# "nylas" routes through Nylas's pre-verified shared Google app — see
# packages/shared/src/nylas.ts. Default: "gmail" until the Nylas swap lands.
EMAIL_PROVIDER="gmail"

# Gmail OAuth (separate grant for gmail.readonly) — only used when EMAIL_PROVIDER=gmail
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI="http://localhost:3100/api/gmail/callback"
GMAIL_PUBSUB_TOPIC="projects/your-gcp-project/topics/kyujin-gmail"

# Nylas (only used when EMAIL_PROVIDER=nylas) — sign up at https://dashboard.nylas.com
# Note: Nylas v3 server-side flow authenticates with the API key alone; we do
# NOT use NYLAS_CLIENT_SECRET (see packages/shared/src/nylas.ts:exchangeCode).
NYLAS_API_KEY=""
NYLAS_CLIENT_ID=""
# Regional API base: https://api.us.nylas.com or https://api.eu.nylas.com
NYLAS_API_URI="https://api.us.nylas.com"
NYLAS_REDIRECT_URI="http://localhost:3100/api/email/callback"
# HMAC secret Nylas uses to sign webhook payloads (set when creating the webhook)
NYLAS_WEBHOOK_SECRET=""

# Database (Supabase / Neon Postgres)
DATABASE_URL=""

# Vercel AI Gateway
AI_GATEWAY_API_KEY=""

# Cron auth — header value Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET="generate with: openssl rand -base64 32"

# Feedback form (Resend)
RESEND_API_KEY=""
FEEDBACK_FROM_EMAIL="Yume Feedback <feedback@yume.app>"
FEEDBACK_TO_EMAIL=""

# Stripe billing
# Secret API key (sk_test_… in dev, sk_live_… in prod) — Dashboard › Developers › API keys
STRIPE_SECRET_KEY=""
# Webhook signing secret (whsec_…) — Dashboard › Developers › Webhooks › endpoint signing secret
# In dev: `stripe listen --forward-to http://localhost:3100/api/billing/webhook` prints one
STRIPE_WEBHOOK_SECRET=""
# Price IDs created in Dashboard › Products. Each plan needs both cadences.
STRIPE_PRICE_STANDARD_MONTHLY=""
STRIPE_PRICE_STANDARD_ANNUAL=""
STRIPE_PRICE_PREMIUM_MONTHLY=""
STRIPE_PRICE_PREMIUM_ANNUAL=""
# Public origin used as Checkout success_url / cancel_url base
NEXT_PUBLIC_APP_URL="http://localhost:3100"

# Apple App Store billing (StoreKit + App Store Server API)
# Bundle ID from Xcode / App Store Connect (matches the iOS app's bundle)
APPLE_BUNDLE_ID="app.yume.kyujin"
# Numeric appAppleId from App Store Connect › App Information › Apple ID. Omit in sandbox-only setups.
APPLE_APP_APPLE_ID=""
# Environment for JWS verification. Use "Sandbox" for dev/TestFlight, "Production" for live App Store.
APPLE_ENVIRONMENT="Sandbox"
# App Store Server API key (App Store Connect › Users and Access › Keys › In-App Purchase)
APPLE_ISSUER_ID=""
APPLE_KEY_ID=""
# PEM-encoded P8 private key body (between -----BEGIN PRIVATE KEY----- markers, newlines kept).
# In .env, escape newlines as \n; the loader at lib/apple.ts un-escapes them.
APPLE_PRIVATE_KEY=""
# Apple Root CA G3 DER certificate, base64-encoded. Download from
# https://www.apple.com/certificateauthority/AppleRootCA-G3.cer then
# `base64 -i AppleRootCA-G3.cer | pbcopy`. Required for verifying signed
# transactions and webhook notifications.
APPLE_ROOT_CERT_BASE64=""
# StoreKit product IDs created in App Store Connect. Must match exactly.
APPLE_PRODUCT_STANDARD_MONTHLY=""
APPLE_PRODUCT_STANDARD_ANNUAL=""
APPLE_PRODUCT_PREMIUM_MONTHLY=""
APPLE_PRODUCT_PREMIUM_ANNUAL=""
