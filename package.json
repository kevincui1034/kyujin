{
  "name": "kyujin",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:push": "pnpm --filter @kyujin/db db:push",
    "db:migrate": "pnpm --filter @kyujin/db db:migrate",
    "db:studio": "pnpm --filter @kyujin/db db:studio",
    "web": "pnpm --filter @kyujin/web",
    "mobile": "pnpm --filter @kyujin/mobile"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.7",
      "@types/react-dom": "^19.0.3"
    }
  }
}
